apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: ballista-executor
  namespace: ${NAMESPACE}
spec:
  selector:
    matchLabels: { app: ballista-executor }
  template:
    metadata:
      labels: { app: ballista-executor }
    spec:
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - { key: node-role.kubernetes.io/control-plane, operator: DoesNotExist }
      containers:
        - name: executor
          image: ballista-executor:${IMAGE_TAG}
          imagePullPolicy: Never
          args:
            - --bind-host=0.0.0.0
            - --bind-port=50051
            - --scheduler-host=ballista-scheduler
            - --scheduler-port=50050
            - --work-dir=/work
            - --external-host=$(POD_IP)
            # Run exactly TASK_SLOTS concurrent tasks (one partition each). With
            # the CPU pin below this equals the CPU budget, so slots == cores
            # and we never schedule more tasks than the executor has cores.
            - --concurrent-tasks=${TASK_SLOTS}
            # Give DataFusion a memory BUDGET so joins/aggregates SPILL to disk
            # instead of allocating without limit. Without this the executor uses
            # an unbounded memory pool and a big JOB join (e.g. cast_info, 36M
            # rows) x TASK_SLOTS concurrent tasks eats the whole host -> OOM ->
            # node hang. The executor splits this into a FairSpillPool of
            # EXEC_MEM_POOL/concurrent_tasks per task. Keep it below the cgroup
            # limit (EXEC_MEM_LIMIT) so spilling kicks in before the OOM-killer.
            - --memory-pool-size=${EXEC_MEM_POOL}
          # Pin every executor's CPU to exactly TASK_SLOTS cores (request==limit,
          # CFS-capped) so all nodes look IDENTICAL despite 16 vs 20 real cores
          # (HT disabled via setup-node.sh) - cores_per_executor is one number.
          # Memory IS capped (EXEC_MEM_LIMIT). Leaving it unbounded let a heavy
          # JOB join grab the WHOLE host (~62 GiB) and trigger a system-wide OOM
          # that hung the node (kubelet/sshd die -> NotReady; killed node-2 &
          # node-3). A cgroup memory limit instead OOM-kills just the pod (the
          # job fails, k8s restarts it) and the HOST survives. Keep EXEC_MEM_LIMIT
          # well below node RAM (headroom for OS + kubelet + CNI). TASK_SLOTS must
          # be <= the smallest node's allocatable CPU or pods stay Pending.
          resources:
            requests: { cpu: "${TASK_SLOTS}" }
            limits:   { cpu: "${TASK_SLOTS}", memory: "${EXEC_MEM_LIMIT}" }
          env:
            - name: POD_IP
              valueFrom:
                fieldRef: { fieldPath: status.podIP }
          volumeMounts:
            - { name: data, mountPath: ${DATA_DIR}, readOnly: true }
            - { name: work, mountPath: /work }
      volumes:
        - name: data
          hostPath: { path: ${DATA_DIR}, type: Directory }
        - name: work
          hostPath: { path: ${WORK_DIR}, type: DirectoryOrCreate }
