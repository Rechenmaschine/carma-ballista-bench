# s3-central: the dataset lives on ONE MinIO node; every scan reads it remotely
# over S3. Compute tier is identical to local-scan (all workers stay executors),
# so the A/B isolates the data-source variable. Layered on top of ./.env.
STORAGE=s3
BUCKET=carma-imdb
LOCATION_PREFIX=s3://$BUCKET/imdb
MANIFESTS="experiments/s3-central/manifests/scheduler.yaml.tmpl experiments/s3-central/manifests/executor.yaml.tmpl experiments/s3-central/manifests/minio.yaml.tmpl"

MINIO_NODE=$CONTROL_NODE        # storage node; control node keeps all workers as executors
MINIO_PORT=9000                 # local port for stage.sh's upload port-forward
MINIO_DATA_DIR=$ROOT/minio      # hostPath bucket store on $MINIO_NODE (survives redeploys)
MINIO_EGRESS_BW="${MINIO_EGRESS_BW:-}"   # e.g. "1G" caps aggregate read throughput; empty = unshaped. Override via env (bits/s, k8s Quantity).

# S3 creds + endpoint -> AmazonS3Builder::from_env() in the scheduler+executor pods.
# minioadmin/minioadmin are MinIO's defaults; fine for an isolated bench cluster.
AWS_ENDPOINT=http://minio:9000  # in-cluster MinIO Service DNS
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_ALLOW_HTTP=true
